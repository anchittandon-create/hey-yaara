# Environment Variables for Yaara

# LLM Configuration (Free TTS/STT Setup)
# This app now uses free Web Speech API for TTS and STT
# For the conversational AI backend, choose one of the free options below:

# Option 1: Groq API (Recommended - Free tier available)
# Get your API key from: https://console.groq.com
VITE_LLM_PROVIDER=groq
VITE_LLM_API_KEY=your_groq_api_key_here

# Option 2: Alternative - HuggingFace Inference API (Free tier)
# Get your API key from: https://huggingface.co/settings/tokens
# VITE_LLM_PROVIDER=huggingface  
# VITE_LLM_API_KEY=your_huggingface_api_key_here

# Supabase Configuration (for future features)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
